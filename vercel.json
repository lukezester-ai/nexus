{
  "version": 2,
  "framework": "vite",
  "buildCommand": "cd artifacts/nexus && pnpm install && pnpm run build",
  "outputDirectory": "artifacts/nexus/dist",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://nexus-api.onrender.com/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
